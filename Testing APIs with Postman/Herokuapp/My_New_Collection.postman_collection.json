        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "//environment",
                  "var jsonData = pm.response.json();",
                  "pm.environment.set(\"token\", jsonData.token);",
                  "",
                  "// Test 1: Validate status code is 200",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Test 2: Validate response contains \"user\" object with required properties",
                  "pm.test(\"Response contains user object with required properties\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property(\"user\");",
                  "    pm.expect(jsonData.user).to.have.property(\"_id\");",
                  "    pm.expect(jsonData.user).to.have.property(\"firstName\");",
                  "    pm.expect(jsonData.user).to.have.property(\"lastName\");",
                  "    pm.expect(jsonData.user).to.have.property(\"email\");",
                  "});",
                  "",
                  "// Test 3: Validate response contains \"token\" property that is a non-empty string",
                  "pm.test(\"Response contains a non-empty token string\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property(\"token\");",
                  "    pm.expect(jsonData.token).to.be.a(\"string\");",
                  "    pm.expect(jsonData.token).to.not.be.empty;",
                  "});",
                  "",
                  "// Test 4: Validate email in response matches the email sent in request",
                  "pm.test(\"Email in response matches request email\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    const requestBody = JSON.parse(pm.request.body.raw);",
                  "    pm.expect(jsonData.user.email).to.equal(requestBody.email);",
                  "});",
                  "",
                  "// Test 5: Validate response time is under 1000ms",
                  "pm.test(\"Response time is under 1000ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
