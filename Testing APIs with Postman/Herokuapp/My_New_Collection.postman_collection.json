        {
          "name": "Cleanup - Delete Contact",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Pre-request script to fetch and set contactId before DELETE",
                  "pm.sendRequest({",
                  "    url: 'https://thinking-tester-contact-list.herokuapp.com/contacts',",
                  "    method: 'GET',",
                  "    header: {",
                  "        'Authorization': 'Bearer ' + pm.environment.get('token')",
                  "    }",
                  "}, function (err, response) {",
                  "    // Handle request errors",
                  "    if (err) {",
                  "        console.error('Failed to fetch contact list:', err);",
                  "        throw new Error('Unable to fetch contact list. Request failed: ' + err);",
                  "    }",
                  "    ",
                  "    // Check if response is successful",
                  "    if (response.code !== 200) {",
                  "        console.error('Failed to fetch contact list. Status:', response.code);",
                  "        throw new Error('Unable to fetch contact list. Status code: ' + response.code);",
                  "    }",
                  "    ",
                  "    // Parse response body",
                  "    let contacts;",
                  "    try {",
                  "        contacts = response.json();",
                  "    } catch (parseError) {",
                  "        console.error('Failed to parse response:', parseError);",
                  "        throw new Error('Unable to parse contact list response');",
                  "    }",
                  "    ",
                  "    // Check if contacts array exists and has at least one contact",
                  "    if (!contacts || !Array.isArray(contacts) || contacts.length === 0) {",
                  "        console.error('Contact list is empty');",
                  "        throw new Error('No contacts available to delete. Contact list is empty.');",
                  "    }",
                  "    ",
                  "    // Extract first contact's _id",
                  "    const firstContactId = contacts[0]._id;",
                  "    ",
                  "    if (!firstContactId) {",
                  "        console.error('First contact does not have an _id field');",
                  "        throw new Error('Unable to extract contact ID from the first contact');",
                  "    }",
                  "    ",
                  "    // Set contactId in environment",
                  "    pm.environment.set('contactId', firstContactId);",
                  "    console.log('Successfully set contactId:', firstContactId);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
